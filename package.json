{
  "name": "keystone-app",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "dev": "keystone dev",
    "start": "keystone start",
    "keystone:dev": "keystone dev --verbose",
    "keystone:build": "keystone build",
    "keystone:start": "keystone start",
    "next:dev": "next dev -p 4000",
    "next:build": "next build",
    "next:start": "next start",
    "build": "keystone build --no-ui && next build",
    "postinstall": "keystone postinstall",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@apollo/client": "^3.12.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@keystone-6/auth": "^8.0.0",
    "@keystone-6/core": "^6.0.0",
    "@keystone-6/fields-document": "^9.0.0",
    "@mui/material": "^9.0.1",
    "dotenv": "^16.4.7",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.10.4",
    "next": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@jest/globals": "^29.7.0",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.10",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-perf": "^3.3.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.4.2",
    "prisma": "5.19.0",
    "react": "^18.3.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.5.0"
  },
  "overrides": {
    "graphql-ws": "^5.16.2"
  }
